import random
while True:
    print("Welcome to your personal movie recommender")
    print("Your mood today?")
    print("1. Happy 2. Sad 3. Bored 4. Motivated 5. Romantic 6. Excited 7. Stressed 8. Adventerous")
    mood=input("Enter mood").strip().capitalize()
    if mood=="Happy":
        recommend=random.choice(["Zootopia", "Tangled", "Finding Nemo"])
        print(recommend)
    elif mood=="Sad":
        recommend=random.choice(["The Secret Life of Walter Mitty", "Up", "Soul"])
        print(recommend)
    elif mood=="Bored":
        recommend=random.choice(["Jumanji", "Free Guy", "Spider-Man: Into the Spider-Verse"])
        print(recommend)
    elif mood=="Motivated":
        recommend=random.choice(["The Pursuit of Happyness", "Hidden Figures", "Rocky"])
        print(recommend)
    elif mood=="Romantic":
        recommend=random.choice(["The Proposal", "10 Things I Hate About You", "Enchanted"])
        print(recommend)
    elif mood=="Excited":
        recommend=random.choice(["Top Gun: Maverick", "Avengers: Endgame", "Mission: Impossible"])
        print(recommend)
    elif mood=="Stressed":
        recommend=random.choice(["Ratatouille", "Paddington 2", "Luca"])
        print(recommend)
    elif mood=="Adventurous":
        recommend=random.choice(["Interstellar", "Jurassic Park", "The Martian"])
        print(recommend)
    else:
        print("Sorry, try again.")
    ch=input("Try again?")
    if ch=="n":
        break
    
    
